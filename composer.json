{
    "name": "mundophpbb/helpdeskkb",
    "type": "phpbb-extension",
    "description": "Knowledge Base integrada ao Help Desk para phpBB.",
    "homepage": "https://www.mundophpbb.com",
    "version": "1.0.8",
    "time": "2026-03-31",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "MundoPHPBB",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "~1.0"
    },
    "extra": {
        "display-name": "HelpDesk Knowledge Base",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0"
        },
        "version-check": {
            "host": "mundophpbb.com.br",
            "directory": "/ext/helpdeskkb",
            "filename": "version"
        }
    }
}
